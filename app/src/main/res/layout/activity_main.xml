<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".MainActivity">

    <!-- Premium Custom Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar_layout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/app_surface"
        android:elevation="4dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="M4Di"
            android:textColor="@color/gold"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/app_sub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="TV"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/app_title"
            app:layout_constraintStart_toEndOf="@id/app_title" />

        <TextView
            android:id="@+id/app_lite_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:background="@drawable/badge_bg"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="LITE"
            android:textColor="@color/black"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/app_title"
            app:layout_constraintTop_toTopOf="@id/app_title"
            app:layout_constraintStart_toEndOf="@id/app_sub_title" />

        <TextView
            android:id="@+id/txt_developer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/developer_brand"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/app_title"
            tools:ignore="SmallSp" />

        <!-- Theme Switcher -->
        <ImageButton
            android:id="@+id/btn_theme_toggle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ubah Tema"
            android:src="@drawable/ic_play"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_add_playlist" />

        <!-- Add Playlist Button -->
        <ImageButton
            android:id="@+id/btn_add_playlist"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tambah Playlist"
            android:src="@drawable/ic_add"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Sleek Custom Search Box -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_container"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="@color/app_surface"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/search_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_search"
                app:tint="@color/gold"
                android:contentDescription="@string/search_hint" />

            <EditText
                android:id="@+id/search_edit_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toEndOf="@id/search_icon"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:hint="@string/search_hint"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp"
                android:maxLines="1"
                android:importantForAutofill="no" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Custom styled TabLayout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginTop="4dp"
        android:background="@color/transparent"
        app:tabBackground="@color/transparent"
        app:tabIndicatorColor="@color/gold"
        app:tabIndicatorHeight="3dp"
        app:tabRippleColor="@color/ripple_color"
        app:tabSelectedTextColor="@color/gold"
        app:tabTextColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/search_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_all" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_favorites" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Loader views -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/gold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/txt_loading_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/loading_playlist"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/progress_loading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Error state layout -->
    <LinearLayout
        android:id="@+id/error_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_error_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:text="@string/fetch_failed"
            android:textColor="@color/color_error"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/retry"
            android:backgroundTint="@color/gold"
            android:textColor="@color/black" />
    </LinearLayout>

    <TextView
        android:id="@+id/txt_empty_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_channel_found"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Validator & Scan Panel Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/validator_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="6dp"
        app:cardCornerRadius="14dp"
        app:cardBackgroundColor="@color/app_surface"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tab_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Stats Label -->
            <TextView
                android:id="@+id/txt_validator_stats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Validasi channel untuk memilah link aktif."
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_start_validation"
                app:layout_constraintBottom_toTopOf="@id/filter_scroll_view"/>

            <!-- Action Button -->
            <Button
                android:id="@+id/btn_start_validation"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:backgroundTint="@color/gold"
                android:text="Pindai"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Divider -->
            <View
                android:id="@+id/validator_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_color"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/btn_start_validation"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Horizontal Scroll View for filter pills -->
            <HorizontalScrollView
                android:id="@+id/filter_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/validator_divider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="2dp">

                    <!-- Filter All -->
                    <TextView
                        android:id="@+id/chip_filter_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semua"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/chip_bg_selected"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />

                    <!-- Filter Online -->
                    <TextView
                        android:id="@+id/chip_filter_online"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟢 Online"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:background="@drawable/chip_bg_unselected"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />

                    <!-- Filter Offline -->
                    <TextView
                        android:id="@+id/chip_filter_offline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔴 Offline"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:background="@drawable/chip_bg_unselected"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:layout_marginEnd="8dp" />

                    <!-- Filter Unchecked -->
                    <TextView
                        android:id="@+id/chip_filter_unchecked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚪ Belum Dicek"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:background="@drawable/chip_bg_unselected"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp" />

                </LinearLayout>
            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- The actual channels list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_channels"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:clipToPadding="false"
        android:paddingHorizontal="6dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/validator_panel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
