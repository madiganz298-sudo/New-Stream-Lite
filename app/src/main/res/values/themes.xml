<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.M4DiTV" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/gold</item>
        <item name="colorSecondaryVariant">@color/gold_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        
        <!-- Status bar and navigation bar integration -->
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
